{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/contact",
      "dest": "/api/contact.js"
    },
    {
      "src": "/api/repos",
      "dest": "/api/repos.js"
    },
    {
      "src": "/api/resume",
      "dest": "/api/resume.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
